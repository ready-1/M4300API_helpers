# M4300 API Helper Configuration

# Production Configuration
M4300_HOST=switch.example.com
M4300_USERNAME=admin
M4300_PASSWORD=your-password
M4300_PORT=8443
M4300_VERIFY_SSL=true
M4300_TIMEOUT=30
M4300_RATE_LIMIT=10
M4300_TOKEN_REFRESH_MARGIN=300

# Test Configuration (for integration tests with --live-switch)
M4300_TEST_HOST=test-switch.example.com
M4300_TEST_USERNAME=test-admin
M4300_TEST_PASSWORD=test-password

# Development Configuration
PYTHONPATH=src
PYTEST_ADDOPTS="-v --cov=m4300api_helpers --cov-report=term-missing"
